# LLM provider — swap these three to change provider
LLM_ENDPOINT=https://api.minimax.io/v1
LLM_API_KEY=your_llm_api_key
LLM_MODEL=MiniMax-M3

# To switch to Qwen via TrueFoundry, only change the three lines above:
# LLM_ENDPOINT=https://your-truefoundry-endpoint/v1/chat/completions
# LLM_API_KEY=your_truefoundry_key
# LLM_MODEL=qwen-plus

# Moss (semantic search over KB)
MOSS_PROJECT_ID=your_project_id
MOSS_PROJECT_KEY=your_project_key
MOSS_INDEX_NAME=what-now-kb

# Unsiloed (optional document parsing before Moss indexing)
UNSILOED_API_KEY=
UNSILOED_BASE_URL=https://prod.visionapi.unsiloed.ai

# Server
PORT=8000
LLM_TIMEOUT_SECONDS=15

# Demo mode — deterministic Jake script (true) or real LLM (false, default)
DEMO_MODE=false

# Apify (nearby urgent care / attorney search)
APIFY_API_KEY=your_apify_key
